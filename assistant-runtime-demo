#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DEMO_BIN="$SCRIPT_DIR/target/debug/assistant-runtime-demo"

if [ ! -x "$DEMO_BIN" ]; then
  echo "missing built demo binary: $DEMO_BIN" >&2
  echo "build it once with: cargo build" >&2
  exit 1
fi

exec "$DEMO_BIN" "$@"
