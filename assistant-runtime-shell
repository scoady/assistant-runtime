#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SHELL_BIN="$SCRIPT_DIR/target/debug/assistant-runtime-shell"

if [ ! -x "$SHELL_BIN" ]; then
  echo "missing built shell binary: $SHELL_BIN" >&2
  echo "build it once with: cargo build" >&2
  exit 1
fi

exec "$SHELL_BIN" "$@"
